{
  "name": "vessel",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev:backend": "pnpm --filter @vessel/backend dev",
    "start:backend": "pnpm --filter @vessel/backend start",
    "dev:frontend": "pnpm --filter @vessel/frontend dev",
    "test:cli": "pnpm --filter @vessel/backend test:cli",
    "test:protocol": "pnpm --filter @vessel/shared test",
    "dep-cruiser:check": "dependency-cruiser packages/",
    "vessel-core": "pnpm --filter @vessel/backend exec tsx src/cli/vessel-core.ts",
    "eva:status": "node scripts/eva-status.mjs",
    "eva:hook": "node scripts/eva-hook.mjs",
    "eva:sessions": "node scripts/eva-sessions.mjs",
    "eva:collect": "node scripts/eva-collect.mjs",
    "migrate:eva-to-vessel": "pnpm --filter @vessel/backend exec tsx ../../scripts/migrate-eva-to-vessel.ts",
    "import:debate-log": "pnpm --filter @vessel/backend exec tsx ../../scripts/import-debate-log.ts"
  },
  "packageManager": "pnpm@9.0.0",
  "devDependencies": {
    "dependency-cruiser": "^17.4.0",
    "tsx": "^4.19.0"
  }
}
