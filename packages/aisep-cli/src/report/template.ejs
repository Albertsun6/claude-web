<!DOCTYPE html>
<html lang="zh">
<head>
<meta charset="utf-8">
<title>AISEP Report — <%= report.workspace.name %></title>
<style>
:root {
  --fg: #1a1a1a;
  --muted: #666;
  --bg: #fafafa;
  --card: #fff;
  --border: #ddd;
  --ok: #1a7f37;
  --fail: #cf222e;
  --cancelled: #9a6700;
  --pending: #8c8c8c;
  --accent: #0969da;
}
* { box-sizing: border-box; }
body {
  margin: 0;
  font: 14px/1.5 -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
  color: var(--fg);
  background: var(--bg);
}
header {
  padding: 24px 32px;
  background: var(--card);
  border-bottom: 1px solid var(--border);
}
h1 { margin: 0 0 4px; font-size: 20px; }
h2 { margin: 0 0 12px; font-size: 16px; }
.subtle { color: var(--muted); font-size: 12px; }
main { padding: 24px 32px; max-width: 1200px; }
section {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 16px 20px;
  margin-bottom: 16px;
}
table { width: 100%; border-collapse: collapse; font-size: 13px; }
th, td { text-align: left; padding: 6px 8px; border-bottom: 1px solid var(--border); }
th { font-weight: 600; background: #f6f8fa; }
.status-succeeded { color: var(--ok); }
.status-failed { color: var(--fail); }
.status-cancelled { color: var(--cancelled); }
.status-pending, .status-skipped { color: var(--pending); }
.role-parent { font-weight: 600; }
.role-child { padding-left: 16px; color: var(--muted); }
code { background: #f6f8fa; padding: 1px 4px; border-radius: 3px; font-size: 12px; }
details { margin: 6px 0; }
summary { cursor: pointer; padding: 4px 0; user-select: none; }
.check-ok::before { content: "✓"; color: var(--ok); margin-right: 4px; }
.check-fail::before { content: "✗"; color: var(--fail); margin-right: 4px; }
.mermaid { background: var(--card); }
.kvp { display: grid; grid-template-columns: 140px 1fr; gap: 4px 12px; font-size: 13px; }
.kvp dt { color: var(--muted); }
.kvp dd { margin: 0; }
.empty { color: var(--muted); font-style: italic; padding: 12px 0; }

@media print {
  body { background: white; }
  main { padding: 0; max-width: 100%; }
  section { border: 1px solid #999; box-shadow: none; page-break-inside: avoid; }
  header { padding: 12px 0; }
  .mermaid { page-break-inside: avoid; }
  details[open] summary { font-weight: 600; }
  details:not([open]) > *:not(summary) { display: none; }
}
</style>
</head>
<body>

<header>
  <h1>AISEP Report — <%= report.workspace.name %></h1>
  <div class="subtle">
    Workspace <code><%= report.workspace.cwd %></code> ·
    Generated <%= new Date(report.generatedAt).toISOString() %> ·
    <%= report.stages.length %> stage_runs ·
    <%= report.parallelGroups.length %> fan-out group(s)
  </div>
</header>

<main>

<section id="summary">
  <h2>Summary</h2>
  <dl class="kvp">
    <dt>workspace.id</dt><dd><code><%= report.workspace.id %></code></dd>
    <dt>techStack</dt><dd><%= (report.workspace.techStack || []).join(", ") || "—" %></dd>
    <dt>shipCount</dt><dd><%= report.workspace.shipCount %></dd>
    <dt>stages succeeded</dt><dd><%= report.stages.filter(s => s.status === "succeeded").length %> / <%= report.stages.length %></dd>
    <dt>contract_grep checks</dt><dd><%= report.contractGrepChecks.filter(c => c.ok).length %> / <%= report.contractGrepChecks.length %> ok</dd>
    <dt>trace anchors</dt><dd><%= report.traceMatrix.length %></dd>
  </dl>
</section>

<section id="stage-timeline">
  <h2>Stage timeline (Gantt)</h2>
<% if (report.stages.length === 0) { %>
  <p class="empty">No stage_runs.</p>
<% } else { %>
  <div class="mermaid">
gantt
    title AISEP Stage Chain
    dateFormat x
    axisFormat %H:%M:%S
<% report.stages.forEach((stage, idx) => { %>
    section <%= stage.stage %><% if (stage.subStageName) { %> · <%= stage.subStageName %><% } %>
    <%= stage.stage %><% if (stage.subStageName) { %>·<%= stage.subStageName %><% } %> :<% if (stage.status === "failed" || stage.status === "cancelled") { %>crit, <% } %>s<%= idx %>, <%= stage.startedAt || (report.generatedAt - 60_000) %>, <%= stage.endedAt || stage.startedAt || report.generatedAt %>
<% }); %>
  </div>
<% } %>
</section>

<section id="fanout-tree">
  <h2>Parallel groups (fan-out / fan-in)</h2>
<% if (report.parallelGroups.length === 0) { %>
  <p class="empty">No parallel groups (linear chain).</p>
<% } else { %>
<% report.parallelGroups.forEach((group, idx) => { %>
  <h3 style="font-size:14px; margin:8px 0">
    parent: <code><%= group.parentId %></code>
    (<%= group.parentStage %>, direction=<%= group.direction %>)
  </h3>
  <div class="mermaid">
flowchart <%= group.direction === "in" ? "BT" : "TD" %>
    P<%= idx %>["parent · <%= group.parentStage %>"]
<% group.childIds.forEach((cid, ci) => { %>
    C<%= idx %>_<%= ci %>["<%= group.childNames[cid] || cid %>"]
    P<%= idx %> --> C<%= idx %>_<%= ci %>
<% if (group.direction === "in" && group.upstreamPredecessorByChildId[cid]) { %>
    U<%= idx %>_<%= ci %>["upstream <%= group.upstreamPredecessorByChildId[cid].slice(-6) %>"]
    U<%= idx %>_<%= ci %> -.mirrors.-> C<%= idx %>_<%= ci %>
<% } %>
<% }); %>
  </div>
<% if (Object.keys(group.affectsByChildId).length > 0) { %>
  <table style="font-size:12px; margin:6px 0">
    <thead><tr><th>child</th><th>affects</th></tr></thead>
    <tbody>
<% group.childIds.forEach((cid) => { %>
      <tr>
        <td><code><%= group.childNames[cid] || cid.slice(-8) %></code></td>
        <td><code><%= (group.affectsByChildId[cid] || []).join(", ") %></code></td>
      </tr>
<% }); %>
    </tbody>
  </table>
<% } %>
<% }); %>
<% } %>
</section>

<section id="stage-table">
  <h2>Stage_run table</h2>
  <table>
    <thead>
      <tr>
        <th>id</th><th>stage</th><th>role</th><th>status</th><th>duration</th><th>output</th>
      </tr>
    </thead>
    <tbody>
<% report.stages.forEach(stage => { %>
      <tr>
        <td><code><%= stage.id.slice(0, 14) %>…</code></td>
        <td class="role-<%= stage.fanOutRole %>"><%= stage.stage %><% if (stage.subStageName) { %> · <%= stage.subStageName %><% } %></td>
        <td><%= stage.fanOutRole %></td>
        <td class="status-<%= stage.status %>"><%= stage.status %></td>
        <td><%= stage.durationMs !== undefined ? (stage.durationMs / 1000).toFixed(1) + "s" : "—" %></td>
        <td><% if (stage.outputKey) { %><code><%= stage.outputKey %></code><% } else { %>—<% } %></td>
      </tr>
<% }); %>
    </tbody>
  </table>
</section>

<section id="trace-matrix">
  <h2>Trace matrix (REQ → ADR → ZOD → RISK → PATCH)</h2>
  <p class="subtle">Anchor IDs auto-extracted from artifact contents via regex /\b(REQ|ADR|ZOD|RISK|FIX|TEST|G|D|C|P|S)-[A-Za-z0-9]+\b/g.
    Empty cells = not yet referenced in chain.</p>
<% if (report.traceMatrix.length === 0) { %>
  <p class="empty">No trace anchors found. (Run with artifactContents inflow to populate.)</p>
<% } else { %>
  <table>
    <thead>
      <tr><th>Anchor</th><th>Declared in</th><th>ADRs</th><th>Zod schemas</th><th>Patches</th><th>Verify checks</th></tr>
    </thead>
    <tbody>
<% report.traceMatrix.forEach(row => { %>
      <tr>
        <td><code><%= row.anchorId %></code></td>
        <td><%= row.declaredIn || "—" %></td>
        <td><% row.adrRefs.forEach(r => { %><code><%= r %></code> <% }); %></td>
        <td><% row.zodRefs.forEach(r => { %><code><%= r %></code> <% }); %></td>
        <td><% row.patchRefs.forEach(r => { %><code><%= r %></code> <% }); %></td>
        <td><% row.verifyChecks.forEach(r => { %><code><%= r %></code> <% }); %></td>
      </tr>
<% }); %>
    </tbody>
  </table>
<% } %>
</section>

<section id="contract-grep">
  <h2>Contract_grep drill-down</h2>
<% if (report.contractGrepChecks.length === 0) { %>
  <p class="empty">No contract_grep checks found in verify output.</p>
<% } else { %>
<% report.contractGrepChecks.forEach(check => { %>
  <details<% if (!check.ok) { %> open<% } %>>
    <summary class="check-<%= check.ok ? "ok" : "fail" %>"><%= check.name %><% if (check.readFromDisk) { %> <span class="subtle">[read_from_disk]</span><% } %></summary>
    <div style="padding: 6px 0 6px 20px">
      <code style="display:block; white-space:pre-wrap; padding:8px; background:#f6f8fa"><%= check.command %></code>
    </div>
  </details>
<% }); %>
<% } %>
</section>

</main>

<script id="aisep-report-data" type="application/json"><%- JSON.stringify(report) %></script>
<script type="module">
import mermaid from "https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs";
mermaid.initialize({ startOnLoad: true, theme: "default" });
</script>

</body>
</html>
